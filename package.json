{
  "name": "ikabu",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "description": "Discord bot for Splatoon 3 community (ikabu)",
  "main": "build/server.js",
  "scripts": {
    "compile": "prisma generate && tsc -p . && tsc-alias -p tsconfig.json && prisma migrate deploy",
    "start": "pnpm run compile && node -r dotenv/config ./build/server.js dotenv_config_path=./.env",
    "create-migrate": "prisma migrate dev --create-only",
    "migrate-deploy": "prisma migrate deploy",
    "prisma-generate": "prisma generate",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@prisma/adapter-better-sqlite3": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@snazzah/davey": "^0.1.8",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.5.0",
    "canvas": "^3.2.0",
    "config": "^4.1.1",
    "config-reloadable": "^1.0.9",
    "cron": "^2.3.1",
    "crypto-js": "^4.1.1",
    "csv": "^6.0.5",
    "csv-stringify": "^6.0.5",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^1.3.7",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.0.0",
    "js-combinatorics": "^1.5.6",
    "log4js": "^6.7.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.6.7",
    "opusscript": "^0.0.8",
    "tweetnacl": "^1.0.3",
    "wikijs": "^6.3.3"
  },
  "license": "MIT",
  "keywords": [
    "discord",
    "bot",
    "splatoon3"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/cron": "^2.0.1",
    "@types/crypto-js": "^4.1.1",
    "@types/node": "^25.0.1",
    "@types/node-fetch": "^2.6.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.9.5",
    "prisma": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "canvas",
      "ffmpeg-static",
      "lefthook",
      "prisma"
    ]
  }
}
