  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Botを起動 - TypeScript",
      "preLaunchTask": "Compile TypeScript",
      "runtimeArgs": ["-r", "dotenv/config"],
      "program": "${workspaceFolder}/build/server.js",
      "args": ["dotenv_config_path=./.env"],
      "env": {
        "PATH": "${env:HOME}/.local/share/mise/shims:${env:PATH}"
      },
      "outputCapture": "std"
    }
  ]
}
